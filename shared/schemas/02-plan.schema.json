{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-ide-workflows/schemas/02-plan",
  "title": "Content Plan Schema",
  "description": "Schema for validating the 02-plan structured block",
  "type": "object",
  "required": [
    "final_title",
    "ab_ratio",
    "visual_mode",
    "visual_metaphor",
    "tech_stack",
    "comparison_matrix",
    "assumptions_to_verify",
    "demo_design",
    "outline_sections"
  ],
  "properties": {
    "final_title": {
      "type": "string",
      "minLength": 1
    },
    "ab_ratio": {
      "type": "string",
      "pattern": "^\\d+/\\d+$",
      "description": "A-rail/B-rail percentage ratio, e.g. '30/70'"
    },
    "visual_mode": {
      "type": "string",
      "enum": ["real_demo_heavy", "code_motion", "diagrammatic_explain", "mixed"],
      "description": "The primary rendering style of the video"
    },
    "visual_metaphor": {
      "type": "string",
      "description": "Core visual metaphor, e.g. 'Taming the wild horse'"
    },
    "tech_stack": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "The selected and locked technical stack tools"
    },
    "comparison_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tech_dimension", "options"],
        "properties": {
          "tech_dimension": { "type": "string", "description": "e.g. '视频生成', '字幕同步'" },
          "options": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "suitability", "unsuitability", "known_pitfalls", "acceptance_criteria", "evidence_status"],
              "properties": {
                "name": { "type": "string" },
                "suitability": { "type": "string", "description": "适用场景" },
                "unsuitability": { "type": "string", "description": "不适用场景" },
                "known_pitfalls": { "type": "string", "description": "已知踩坑点" },
                "acceptance_criteria": { "type": "string", "description": "验收标准" },
                "evidence_status": {
                  "type": "string",
                  "enum": ["paper_spec", "verified"],
                  "description": "证据状态: paper_spec(仅纸面) 或 verified(已验证)"
                }
              }
            }
          }
        }
      }
    },
    "assumptions_to_verify": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["assumption", "verification_method"],
        "properties": {
          "assumption": { "type": "string", "description": "待验证的纸面假设" },
          "verification_method": { "type": "string", "description": "验证方法/判断标准" }
        }
      }
    },
    "demo_design": {
      "type": "object",
      "required": ["project_context", "prompt_sequence", "pitfalls_to_expose"],
      "properties": {
        "project_context": {
          "type": "string",
          "description": "Project baseline, language, framework"
        },
        "prompt_sequence": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "The exact prompts sent to the AI IDE"
        },
        "pitfalls_to_expose": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Expected failure modes or edge cases where the AI struggles"
        }
      }
    },
    "outline_sections": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["section_name", "key_point", "beat_type", "visual_priority", "scene_template"],
        "properties": {
          "section_name": { "type": "string" },
          "key_point": { "type": "string" },
          "beat_type": {
            "type": "string",
            "enum": ["statement", "demonstration", "transformation", "comparison", "conclusion"],
            "description": "The narrative role of this beat"
          },
          "visual_priority": {
            "type": "string",
            "enum": ["text", "code", "chart", "screen", "mixed"],
            "description": "The main visual element the viewer should focus on"
          },
          "scene_template": { "type": "string", "description": "Scene code like @IntroScene, @TableScene, or @ConceptScene" }
        }
      }
    }
  },
  "additionalProperties": false
}
