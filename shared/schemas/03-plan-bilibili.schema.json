{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-ide-workflows/schemas/03-plan-bilibili",
  "title": "Bilibili Video Plan Schema",
  "description": "Schema for validating the 03-video-planning-bilibili structured block",
  "type": "object",
  "required": [
    "video_spec",
    "scene_storyboards",
    "zoom_crop_directives"
  ],
  "properties": {
    "video_spec": {
      "type": "object",
      "required": ["aspect_ratio", "resolution", "fps"],
      "properties": {
        "aspect_ratio": {
          "type": "string",
          "enum": ["16:9", "9:16", "1:1"],
          "description": "Video aspect ratio for the platform"
        },
        "resolution": {
          "type": "string",
          "description": "Video resolution, e.g. '1920x1080'"
        },
        "fps": {
          "type": "number",
          "description": "Frames per second"
        }
      }
    },
    "scene_storyboards": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["section_ref", "scene_template", "props", "duration_seconds"],
        "properties": {
          "section_ref": {
            "type": "string",
            "description": "Reference to the corresponding section in 02-plan outline"
          },
          "scene_template": {
            "type": "string",
            "description": "Remotion scene template code, e.g. @IntroScene, @TableScene"
          },
          "props": {
            "type": "object",
            "description": "Static props to pass to the scene component"
          },
          "animation_cues": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["frame", "action"],
              "properties": {
                "frame": { "type": "number" },
                "action": { "type": "string", "description": "e.g. 'fade_in', 'highlight_cell', 'zoom_in'" }
              }
            }
          },
          "duration_seconds": {
            "type": "number",
            "description": "Estimated duration for this scene"
          }
        }
      }
    },
    "zoom_crop_directives": {
      "type": "array",
      "description": "Directives for B-track screen recording zoom/crop operations",
      "items": {
        "type": "object",
        "required": ["clip_id", "timestamp_start", "timestamp_end", "focal_point"],
        "properties": {
          "clip_id": { "type": "string" },
          "timestamp_start": { "type": "string", "description": "Start time in mm:ss format" },
          "timestamp_end": { "type": "string", "description": "End time in mm:ss format" },
          "zoom_level": { "type": "number", "description": "Zoom multiplier, e.g. 1.5 for 150%" },
          "focal_point": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number", "description": "Focal X coordinate (0-1)" },
              "y": { "type": "number", "description": "Focal Y coordinate (0-1)" }
            }
          }
        }
      }
    },
    "template_tickets": {
      "type": "array",
      "description": "Remotion component extension tickets if new templates are needed",
      "items": {
        "type": "object",
        "required": ["id", "name", "physical_path", "props_interface", "animation_spec"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "physical_path": {
            "type": "string",
            "description": "Suggested file path, e.g. video/src/template/scenes/xxx.tsx"
          },
          "props_interface": {
            "type": "string",
            "description": "TypeScript interface definition for the component props"
          },
          "animation_spec": {
            "type": "string",
            "description": "Animation behavior specification in plain text"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
