      "startMs": 18063,
      "endMs": 21374
    },
    {
      "word": "我没有前后端基础，",
      "startMs": 21374,
      "endMs": 23219
    },
    {
      "word": "全程用大白话指挥 AI：",
      "startMs": 23219,
      "endMs": 25678
    },
    {
      "word": "我说要什么、",
      "startMs": 25678,
      "endMs": 26907
    },
    {
      "word": "判断对不对。",
      "startMs": 26907,
      "endMs": 28137
    },
    {
      "word": "这件事三步：",
      "startMs": 28300,
      "endMs": 29548
    },
    {
      "word": "让 AI 帮我找技术路径、",
      "startMs": 29548,
      "endMs": 32251
    },
    {
      "word": "对着约束选型、",
      "startMs": 32251,
      "endMs": 33707
    },
    {
      "word": "最后落地出片。",
      "startMs": 33707,
      "endMs": 35162
    },
    {
      "word": "第一步找路，",
      "startMs": 35284,
      "endMs": 36532
    },
    {
      "word": "我没自己埋头啃文档，",
      "startMs": 36532,
      "endMs": 38611
    },
    {
      "word": "直接把选择题丢给 AI：",
      "startMs": 38611,
      "endMs": 41106
    },
    {
      "word": "想把视频写成代码自动出片，",
      "startMs": 41106,
      "endMs": 43809
    },
    {
      "word": "现在都有哪些现成路子？",
      "startMs": 43809,
      "endMs": 46096
    },
    {
      "word": "它一口气摆了六条——Remotion 走网页那套、",
      "startMs": 46252,
      "endMs": 49697
    },
    {
      "word": "Manim 画数学公式、",
      "startMs": 49697,
      "endMs": 51350
    },
    {
      "word": "MoviePy 和 FFmpeg 做简单拼接，",
      "startMs": 51350,
      "endMs": 54519
    },
    {
      "word": "还有 Motion Canvas、",
      "startMs": 54519,
      "endMs": 56862
    },
    {
      "word": "PixiJS 这些。",
      "startMs": 56862,
      "endMs": 58240
    },
    {
      "word": "名字听着五花八门，",
      "startMs": 58396,
      "endMs": 60342
    },
    {
      "word": "但你扒到底，",
      "startMs": 60342,
      "endMs": 61639
    },
    {
      "word": "全在干同一件事：",
      "startMs": 61639,
      "endMs": 63368
    },
    {
      "word": "拿代码描述画面，",
      "startMs": 63368,
      "endMs": 65098
    },
    {
      "word": "编译成一帧帧，",
      "startMs": 65098,
      "endMs": 66611
    },
    {
      "word": "再合成视频。",
      "startMs": 66611,
      "endMs": 67908
    },
    {
      "word": "这一步只摆路，",
      "startMs": 68068,
      "endMs": 69670
    },
    {
      "word": "先不评好坏。",
      "startMs": 69670,
      "endMs": 71043
    },
    {
      "word": "第二步选型，",
      "startMs": 71164,
      "endMs": 72308
    },
    {
      "word": "这步最容易翻车——你要是直接问 AI 哪个好，",
      "startMs": 72308,
      "endMs": 76692
    },
    {
      "word": "它会跟个老好人似的每个都夸一遍，",
      "startMs": 76692,
      "endMs": 79742
    },
    {
      "word": "你还是不会选。",
      "startMs": 79742,
      "endMs": 81076
    },
    {
      "word": "值钱的是看清每条路什么时候不好使。",
      "startMs": 81077,
      "endMs": 84676
    },
    {
      "word": "所以我反过来逼它：",
      "startMs": 84844,
      "endMs": 86791
    },
    {
      "word": "把每条路的适用场景和会咬人的坑全列出来。",
      "startMs": 86791,
      "endMs": 91119
    },
    {
      "word": "看这张表：",
      "startMs": 91069,
      "endMs": 91940
    },
    {
      "word": "Remotion 适合前端栈和复杂排版，",
      "startMs": 91940,
      "endMs": 95425
    },
    {
      "word": "但你在组件顶层直接读 window，",
      "startMs": 95425,
      "endMs": 98561
    },
    {
      "word": "打包阶段就当场崩，",
      "startMs": 98561,
      "endMs": 100130
    },
    {
      "word": "而且是 BUSL 商业授权；",
      "startMs": 100130,
      "endMs": 102569
    },
    {
      "word": "Manim 排版弱、",
      "startMs": 102724,
      "endMs": 104423
    },
    {
      "word": "渲染慢；",
      "startMs": 104423,
      "endMs": 105103
    },
    {
      "word": "MoviePy 写自适应排版能把人写吐；",
      "startMs": 105103,
      "endMs": 108501
    },
    {
      "word": "FFmpeg 命令跟天书一样。",
      "startMs": 108501,
      "endMs": 111049
    },
    {
      "word": "看清坑，",
      "startMs": 111148,
      "endMs": 111879
    },
    {
      "word": "我再对着自己的需求做减法：",
      "startMs": 111879,
      "endMs": 114255
    },
    {
      "word": "我要一期一个模板换数据批量出几十期、",
      "startMs": 114255,
      "endMs": 117545
    },
    {
      "word": "要 AI 改内容不容易错、",
      "startMs": 117545,
      "endMs": 119921
    },
    {
      "word": "要跨期好维护——这三条一卡，",
      "startMs": 119921,
      "endMs": 122480
    },
    {
      "word": "Remotion 赢了。",
      "startMs": 122480,
      "endMs": 124673
    },
    {
      "word": "跟复制粘贴 HTML 比，",
      "startMs": 124828,
      "endMs": 127503
    },
    {
      "word": "它改一处全系列生效，",
      "startMs": 127503,
      "endMs": 129561
    },
    {
      "word": "AI 也只能乖乖填数据、",
      "startMs": 129561,
      "endMs": 132031
    },
    {
      "word": "不乱跑结构。",
      "startMs": 132031,
      "endMs": 133266
    },
    {
      "word": "代价就一条：",
      "startMs": 133216,
      "endMs": 134330
    },
    {
      "word": "React 栈加 BUSL 授权，",
      "startMs": 134330,
      "endMs": 137486
    },
    {
      "word": "规模化商用要付费——但前端反正是 AI 写、",
      "startMs": 137486,
      "endMs": 141571
    },
    {
      "word": "我把方向，",
      "startMs": 141571,
      "endMs": 142500
    },
    {
      "word": "不算门槛。",
      "startMs": 142500,
      "endMs": 143428
    },
    {
      "word": "一句话：",
      "startMs": 143596,
      "endMs": 144418
    },
    {
      "word": "让 AI 铺信息，",
      "startMs": 144418,
      "endMs": 146267
    },
    {
      "word": "拍板的事留给你自己。",
      "startMs": 146267,
      "endMs": 148321
    },
    {
      "word": "选型定了，",
      "startMs": 148420,
      "endMs": 149628
    },
    {
      "word": "进第三步落地。",
      "startMs": 149628,
      "endMs": 151320
    },
    {
      "word": "好消息是搭引擎也不用你手写，",
      "startMs": 151270,
      "endMs": 154240
    },
    {
      "word": "就是跟 AI 把配置和现成组件对上号。",
      "startMs": 154240,
      "endMs": 158270
    },
    {
      "word": "仓库这台引擎叫 remotion-composer，",
      "startMs": 158428,
      "endMs": 162478
    },
    {
      "word": "干活特别直白：",
      "startMs": 162478,
      "endMs": 163568
    },
    {
      "word": "你写一份配置说清这段画面长啥样，",
      "startMs": 163568,
      "endMs": 166060
    },
    {
      "word": "主程序 Explainer 就看配置里的 type 字段，",
      "startMs": 166060,
      "endMs": 170577
    },
    {
      "word": "自动去找对应组件来渲。",
      "startMs": 170577,
      "endMs": 172290
    },
    {
      "word": "type 写 comparison 就出对比卡，",
      "startMs": 172291,
      "endMs": 175987
    },
    {
      "word": "terminal 是合成终端、",
      "startMs": 175987,
      "endMs": 178297
    },
    {
      "word": "不用真录屏，",
      "startMs": 178297,
      "endMs": 179221
    },
    {
      "word": "还有图表、",
      "startMs": 179221,
      "endMs": 179991
    },
    {
      "word": "分屏。",
      "startMs": 179991,
      "endMs": 180453
    },
    {
      "word": "所以做内容这事，",
      "startMs": 180604,
      "endMs": 182534
    },
    {
      "word": "本质就是挑组件、",
      "startMs": 182534,
      "endMs": 184464
    },
    {
      "word": "填字段。",
      "startMs": 184464,
      "endMs": 185429
    },
    {
      "word": "最省心的一招是：",
      "startMs": 185379,
      "endMs": 187008
    },
    {
      "word": "我从不让 AI 去发明新组件，",
      "startMs": 187008,
      "endMs": 190064
    },
    {
      "word": "只让它照现成的填数据。",
      "startMs": 190064,
      "endMs": 192304
    },
    {
      "word": "比如要张对比卡，",
      "startMs": 192460,
      "endMs": 194211
    },
    {
      "word": "我说左边传统剪辑、",
      "startMs": 194211,
      "endMs": 196181
    },
    {
      "word": "右边代码即视频，",
      "startMs": 196181,
      "endMs": 197933
    },
    {
      "word": "它吐出来就是这么一段配置，",
      "startMs": 197933,
      "endMs": 200778
    },
    {
      "word": "齐活。",
      "startMs": 200778,
      "endMs": 201435
    },
    {
      "word": "为啥稳？",
      "startMs": 201604,
      "endMs": 202916
    },
    {
      "word": "因为每个字段都用 TypeScript 把格式焊死了，",
      "startMs": 202867,
      "endMs": 207543
    },
    {
      "word": "AI 填错漏填，",
      "startMs": 207543,
      "endMs": 208929
    },
    {
      "word": "编译当场报红。",
      "startMs": 208929,
      "endMs": 210142
    },
    {
      "word": "记住：",
      "startMs": 210142,
      "endMs": 210775
    },
    {
      "word": "让 AI 填空，",
      "startMs": 210775,
      "endMs": 212464
    },
    {
      "word": "别让它造轮子。",
      "startMs": 212464,
      "endMs": 213942
    },
    {
      "word": "想要更强辨识度，",
      "startMs": 214108,
      "endMs": 215713
    },
    {
      "word": "还能在现成组件上扩一套自有风格组件库——那是更大的话题，",
      "startMs": 215713,
      "endMs": 221328
    },
    {
      "word": "以后单开一期讲。",
      "startMs": 221328,
      "endMs": 222933
    },
    {
      "word": "落地过程里唯一反复栽我的，",
      "startMs": 223084,
      "endMs": 225806
    },
    {
      "word": "就是 SSR 这个坑。",
      "startMs": 225806,
      "endMs": 228109
    },
    {
      "word": "看左边：",
      "startMs": 228059,
      "endMs": 228632
    },
    {
      "word": "组件顶层直接读了 window，",
      "startMs": 228632,
      "endMs": 230924
    },
    {
      "word": "可 Remotion 打包那会儿跑在 Node 里、",
      "startMs": 230924,
      "endMs": 234649
    },
    {
      "word": "还没进浏览器，",
      "startMs": 234649,
      "endMs": 235652
    },
    {
      "word": "当场就报 ReferenceError、",
      "startMs": 235652,
      "endMs": 238518
    },
    {
      "word": "渲染红屏。",
      "startMs": 238518,
      "endMs": 239234
    },
    {
      "word": "好比人还没进门就伸手拉灯，",
      "startMs": 239234,
      "endMs": 242085
    },
    {
      "word": "灯都没装上，",
