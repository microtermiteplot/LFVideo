  "captions": [
    {
      "word": "这期就一件事：",
      "startMs": 100,
      "endMs": 1373
    },
    {
      "word": "用 Vibe Coding 搭一套渲染引擎，",
      "startMs": 1373,
      "endMs": 5372
    },
    {
      "word": "把视频写成代码、",
      "startMs": 5372,
      "endMs": 6827
    },
    {
      "word": "让 AI 按配置自动出片，",
      "startMs": 6827,
      "endMs": 9190
    },
    {
      "word": "改数据就改片。",
      "startMs": 9190,
      "endMs": 10462
    },
    {
      "word": "先记住一个关键认知：",
      "startMs": 10612,
      "endMs": 12682
    },
    {
      "word": "AI 最强的本事是啃文本和代码，",
      "startMs": 12682,
      "endMs": 15993
    },
    {
      "word": "所以想让渲染自动化，",
      "startMs": 15993,
      "endMs": 18063
